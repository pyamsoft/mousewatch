{
  "name": "mousewatch",
  "version": "2.3.1",
  "main": "index.js",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "start": "vite-node ./src/index.js",
    "lint:eslint": "eslint --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy content .",
    "lint:oxlint": "oxlint --deny-warnings .",
    "lint:tsc": "tsc --strict --noEmit",
    "lint": "$npm_execpath run lint:oxlint && $npm_execpath run lint:tsc && $npm_execpath run lint:eslint",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=24.x"
  },
  "dependencies": {
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "luxon": "3.7.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/luxon": "3.7.1",
    "@types/node": "25.9.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.1",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "npm-check-updates": "22.2.3",
    "oxlint": "1.69.0",
    "prettier": "3.8.4",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite-node": "6.0.0"
  },
  "packageManager": "pnpm@11.6.0"
}
